# Залежності
node_modules/

# Локальні змінні (не публікувати!)
.env
.env.local
.env.*.local

# Згенеровані при npm run build (створюються на хостингу)
js/main.min.js
css/styles.min.css

# Згенеровані WebP (можуть бути створені на хостингу під час build)
public/assets/**/*.webp

# Логи та тимчасові файли
*.log
npm-debug.log*
.DS_Store
